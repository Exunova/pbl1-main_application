{
  "name": "mapro",
  "version": "1.0.0",
  "description": "MAPRO - Multimarket Analytics Portfolio Tracker",
  "private": true,
  "scripts": {
    "install:backend": "bash scripts/install-backend.sh",
    "install:frontend": "bash scripts/install-frontend.sh",
    "install:all": "npm run install:frontend && npm run install:backend",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "bash scripts/test-backend.sh",
    "test:frontend": "bash scripts/test-frontend.sh",
    "test:e2e": "cd frontend && npx playwright test --config=../tests/e2e/playwright.config.mjs",
    "dev": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}